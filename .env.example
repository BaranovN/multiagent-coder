# LLM providers — fill in the ones you want to use.
# At least one provider must be available (Groq, Cerebras, OpenRouter, Gemini,
# OpenAI, Anthropic, or a running local Ollama).

# Groq — free tier, very fast. https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras Cloud — free tier, ~2000 tok/s. Hosts Qwen-3-235B, gpt-oss-120b,
# Llama-3.1-8b. https://cloud.cerebras.ai/ → API keys (starts with `csk-`).
CEREBRAS_API_KEY=

# OpenRouter — one key, many models via `:free` tier (Qwen3 Coder, Llama,
# Gemma, ...). Starts with `sk-or-v1-`. https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini — free tier, blocked in some regions. https://aistudio.google.com/apikey
# If Google blocks you, use OpenRouter or Cerebras (above) to reach similar models.
GEMINI_API_KEY=

# Optional: OpenAI / Anthropic if you want to add paid providers later.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: local Ollama fallback. Run `ollama serve` and pull a model, e.g.
#   ollama pull qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Langfuse tracing. Self-host via docker-compose, or use cloud.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Runtime budgets (override defaults in configs/agents.yaml).
MAC_MAX_ITERATIONS=8
MAC_MAX_TOKENS_PER_RUN=200000
