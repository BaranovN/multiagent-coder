# LLM providers — fill in the ones you want to use.
# At least one of GROQ_API_KEY or GEMINI_API_KEY is required unless you run fully local via Ollama.

# Groq — free tier, very fast. https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — free tier. https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: OpenAI / Anthropic if you want to add paid providers later.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: local Ollama fallback. Run `ollama serve` and pull a model, e.g.
#   ollama pull qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Langfuse tracing. Self-host via docker-compose, or use cloud.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Runtime budgets (override defaults in configs/agents.yaml).
MAC_MAX_ITERATIONS=8
MAC_MAX_TOKENS_PER_RUN=200000
